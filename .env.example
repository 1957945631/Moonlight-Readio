PORT=8787

# AI_PROVIDER can be mock, openai, or domestic.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_STYLE=responses
OPENAI_MODEL=gpt-4.1-mini

# MUSIC_PROVIDER can be local, netease, or netease-cli.
MUSIC_PROVIDER=netease-cli
NETEASE_AUTHORIZED=false
NETEASE_API_BASE=
NETEASE_API_KEY=

# Local NetEase Cloud Music CLI integration.
NETEASE_CLI_PATH=node_modules/.bin/ncm-cli
PROJECT_MPV_PATH=tools/mpv/mpv.exe
